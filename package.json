{
  "name": "agstat-backend",
  "version": "1.0.0",
  "description": "significance (agstat) backend server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon server.js",
    "db-setup": "node ./utils/db-tools.js setup",
    "db-down": "npx knex migrate:down --knexfile=./knexfile.js",
    "db-latest": "npx knex migrate:latest --knexfile=./knexfile.js",
    "db-connect": "psql -U postgres -d agstat",
    "db-connect-prod": "psql -U statsimpleuser -d agstat -h stat-simple-test-db.cm77zzcdkdwp.us-east-2.rds.amazonaws.com",
    "gen-migration": "npx knex migrate:make --knexfile=./knexfile.js",
    "stripe-listen": "stripe listen --forward-to http://localhost:5001/payment/webhooks"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "argon2": "^0.31.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^2.5.1",
    "nodemailer": "^6.9.8",
    "pg": "^8.11.3",
    "stripe": "^14.11.0",
    "uuid": "^9.0.1"
  }
}
